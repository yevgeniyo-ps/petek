{
  "manifest_version": 3,
  "name": "Petek Notes",
  "version": "1.0.0",
  "description": "Quick access to your Petek notes from the browser sidebar",
  "permissions": ["sidePanel", "storage", "identity", "scripting"],
  "host_permissions": ["https://petek.app/*", "https://yevgeniyo-ps.github.io/*"],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Petek Notes"
  }
}
